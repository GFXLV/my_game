<scripts_config.xml>
	<!--
		The contents of this files are passed to the personality script 
		as the first argument in the init function (as a data section). It's 
		grammar is solely defined by the personality script.
	-->

	<space> spaces/main </space>
	
	<player>
		
		<entityType> Avatar </entityType>
		<!--
			This is the entity type the player will be created as.  You must
			implement a Player<class> type (e.g. PlayerAvatar) to use this type
			as a client proxy.
		-->
		
		<startPosition> 0.0 1.0 0.0 </startPosition>
		<startDirection> 1.0 0.0 0.0 </startDirection>
		<!--
			Used by the personality script to provide a start position and
			facing dir for players if there is no space specific spawn point.
		-->

	</player>

	<server>

		<online> true </online>
		<!--
			Whether or not the client actually connects to the server.
		-->
		
		<host> 192.168.56.101 </host>
		<!--
			The VirtualBox server IP - connects to BigWorld loginapp on UDP 20013
		-->

	</server>

	<chat>

		<visibleLines> 6 </visibleLines>
		<!-- Number of lines of chat history visible at once -->

	</chat>

</scripts_config.xml>
